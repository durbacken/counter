rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function uid() { return request.auth.uid; }
    function isAuth() { return request.auth != null; }

    function wsData(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data;
    }

    function isMember(workspaceId) {
      return uid() in wsData(workspaceId).members;
    }

    function isPrivileged(workspaceId) {
      let w = wsData(workspaceId);
      return w.ownerId == uid() ||
        ('admins' in w && uid() in w.admins);
    }

    function isOwner(workspaceId) {
      return wsData(workspaceId).ownerId == uid();
    }

    // ── Users ───────────────────────────────────────────────────────
    // Any signed-in user can look up others by email (needed for invite flow).
    // Only the user themselves can write their own profile.
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && uid() == userId;
    }

    // ── Workspaces ──────────────────────────────────────────────────
    match /workspaces/{workspaceId} {
      // Members can see a workspace; anyone can read if the owner made it public.
      // Use resource.data directly (not get()) so list queries pass rule validation.
      allow read: if (isAuth() && uid() in resource.data.members) ||
                     resource.data.isPublic == true;

      // Any signed-in user can create a workspace they own.
      allow create: if isAuth() &&
        request.resource.data.ownerId == uid() &&
        uid() in request.resource.data.members;

      // Owner/admin can update anything.
      // Regular members may only remove themselves (leave workspace).
      allow update: if isAuth() && (
        isPrivileged(workspaceId) ||
        (isMember(workspaceId) &&
         !request.resource.data.members.hasAny([uid()]) &&
         request.resource.data.members.size() == resource.data.members.size() - 1)
      );

      // Only the owner can delete the workspace.
      allow delete: if isAuth() && isOwner(workspaceId);

      // ── Change history ─────────────────────────────────────────────
      // Members can read and append. Nobody can edit or delete (immutable log).
      match /changes/{changeId} {
        allow read: if isAuth() && isMember(workspaceId);
        allow create: if isAuth() &&
          isMember(workspaceId) &&
          request.resource.data.userId == uid();
        allow update, delete: if false;
      }
    }

    // ── Invites ─────────────────────────────────────────────────────
    // Owner/admin can create invites for their workspace.
    // The invited person (matched by email) can read and update (accept) their invite.
    match /invites/{inviteId} {
      allow read: if isAuth() && (
        isPrivileged(resource.data.workspaceId) ||
        request.auth.token.email == resource.data.email
      );
      allow create: if isAuth() &&
        isPrivileged(request.resource.data.workspaceId);
      allow update: if isAuth() && (
        isPrivileged(resource.data.workspaceId) ||
        request.auth.token.email == resource.data.email
      );
      allow delete: if false;
    }
  }
}
